# API Keys
OPENAI_API_KEY=ANTHROPIC_API_KEY
ANTHROPIC_API_KEY=ANTHROPIC_API_KEY
# Wazuh credentials
WAZUH_API_URL=https://SIEM_IP:55000
WAZUH_API_USER=WAZUH_USERNAME
WAZUH_API_PASSWORD=WAZUH_PASSWORD

# Database
POSTGRES_USER=N8N_USER
POSTGRES_PASSWORD=N8N_PASSWORD
POSTGRES_DB=n8n

# N8N
N8N_BASIC_AUTH_USER=N8N_USERNAME
N8N_BASIC_AUTH_PASSWORD=ADMIN_PASSWORD
WAZUH_INDEXER_URL=https://SIEM_IP:9200
WAZUH_INDEXER_USER=WAZUH_INDEXER_USERNAME
WAZUH_INDEXER_PASSWORD=WZUH_INDEXER_PASSWORD

# ============================================
# OLLAMA — LOCAL LLM
# ============================================
# Suggested model for a nice try: qwen2.5:7b (4.7GB RAM, JSON trusty)
# Demo option: phi3.5 (2.3GB RAM, veloce)
OLLAMA_MODEL=phi3.5
OLLAMA_BASE_URL=http://ollama:11434

# Threads numder CPU inference (use N-1 available cores)
OLLAMA_NUM_THREADS=1

# Keep model in memory between calls (avoid reload)
OLLAMA_KEEP_ALIVE=30m

# ============================================
# OPENROUTER GPT-OSS
# ============================================
# new api keys each 180 days
# choose your local models
OPENROUTER_API_KEY=OPENROUTER_API_KEY
# CHOOSE_YOUR_MODEL
OPENROUTER_MODEL=openai/gpt-oss-120b:free
