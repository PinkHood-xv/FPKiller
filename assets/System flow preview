const FONT = "'JetBrains Mono', 'Fira Code', monospace";

function Node({ x, y, w, h, t, label, sublabel, icon, small }) {
  return (
    <g>
      <rect x={x} y={y} width={w} height={h} rx={6}
        fill={t.bg} stroke={t.border} strokeWidth={1.5} />
      <rect x={x} y={y} width={w} height={2} fill={t.accent} opacity={0.8} />
      <text x={x+w/2} y={y+(small?20:24)} textAnchor="middle"
        fontFamily={FONT} fontSize={small?9:11} fontWeight="700"
        fill={t.accent} letterSpacing="0.08em">{icon} {label}</text>
      {sublabel && <text x={x+w/2} y={y+(small?34:40)} textAnchor="middle"
        fontFamily={FONT} fontSize={small?7.5:8.5}
        fill={theme.text.secondary} letterSpacing="0.04em">{sublabel}</text>}
    </g>
  );
}

function Arr({ x1,y1,x2,y2, color, dashed, label, lx, ly }) {
  const id = `m${color.replace('#','')}${x1}${y1}`;
  return (
    <g>
      <defs>
        <marker id={id} markerWidth={8} markerHeight={8} refX={6} refY={3} orient="auto">
          <path d="M0,0 L0,6 L8,3 z" fill={color}/>
        </marker>
      </defs>
      <line x1={x1} y1={y1} x2={x2} y2={y2} stroke={color} strokeWidth={1.5}
        strokeDasharray={dashed?"5,4":undefined}
        markerEnd={`url(#${id})`} opacity={0.85}/>
      {label && <text x={lx??(x1+x2)/2} y={ly??((y1+y2)/2-5)} textAnchor="middle"
        fontFamily={FONT} fontSize={7.5} fill={color} opacity={0.9} letterSpacing="0.06em">{label}</text>}
    </g>
  );
}

function Dot({ x1,y1,x2,y2,color,phase }) {
  const t = (phase%12)/12;
  return (
    <circle cx={x1+(x2-x1)*t} cy={y1+(y2-y1)*t} r={3} fill={color} opacity={0.85}>
      <animate attributeName="opacity" values="0;1;0" dur="1.8s" repeatCount="indefinite"/>
    </circle>
  );
}

